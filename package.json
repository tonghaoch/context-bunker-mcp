{
  "name": "context-bunker-mcp",
  "version": "0.1.1",
  "description": "Pre-computed codebase intelligence MCP server. Zero API keys. Code never leaves your machine.",
  "type": "module",
  "bin": {
    "context-bunker-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external web-tree-sitter --external better-sqlite3",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonghaoch/context-bunker-mcp.git"
  },
  "homepage": "https://github.com/tonghaoch/context-bunker-mcp#readme",
  "bugs": {
    "url": "https://github.com/tonghaoch/context-bunker-mcp/issues"
  },
  "author": "Michael Chen",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.25.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "mcp",
    "codebase",
    "indexer",
    "tree-sitter",
    "ai",
    "context",
    "code-intelligence"
  ],
  "license": "MIT"
}
